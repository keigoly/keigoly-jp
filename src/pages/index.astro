---
// keigoly.jp — ポータル。FromSoftware 型の斜めスライスから OFFICIAL / CLAW を選ぶ。
import "../styles/global.css";

const SITE_TITLE = "KEIGOLY";
const SITE_DESC =
  "KEIGOLY ポータル — オフィシャルサイトと『Clawくんと歩む』への入口。";
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL("/hero/slide-1.png", Astro.site);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{SITE_TITLE}</title>
    <meta name="description" content={SITE_DESC} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:title" content={SITE_TITLE} />
    <meta property="og:description" content={SITE_DESC} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <main class="animate-fade-in relative h-dvh w-full overflow-hidden bg-black opacity-0">
      <!-- 斜めスライスゲート -->
      <div class="gates" role="navigation" aria-label="サイト選択">
        <a href="https://official.keigoly.jp/" class="gate">
          <div class="gate-bg">
            <img
              src="/hero/slide-1.png"
              alt=""
              class="gate-photo"
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="gate-label">
            <span class="en">OFFICIAL</span>
            <span class="rule"></span>
            <span class="ja">オフィシャルサイト</span>
            <span class="desc">プロフィール・作品・ブログ</span>
            <span class="enter">ENTER</span>
          </div>
          <span class="sr-only">オフィシャルサイトへ</span>
        </a>

        <a href="https://claw.keigoly.jp/" class="gate">
          <div class="gate-bg gate-bg-claw">
            <img
              src="/hero/keigoly-walking.png"
              alt=""
              class="walk-figure"
              loading="eager"
            />
            <img
              src="/hero/claw-lookup.png"
              alt=""
              class="claw-figure"
              loading="eager"
            />
          </div>
          <div class="gate-label">
            <span class="en">CLAW</span>
            <span class="rule"></span>
            <span class="ja">Clawくんと歩む</span>
            <span class="desc">持たざる者による AI 黙示録</span>
            <span class="enter">ENTER</span>
          </div>
          <span class="sr-only">Clawくんと歩むへ</span>
        </a>
      </div>

      <!-- ヘッダー (スライスの上・ロゴのみ) -->
      <header
        class="pointer-events-none absolute inset-x-0 top-0 z-10 flex items-center px-6 py-5 md:px-10 md:py-7"
      >
        <a href="/" class="pointer-events-auto" aria-label="KEIGOLY">
          <img src="/logo.png" alt="KEIGOLY" class="h-6 w-auto md:h-8" />
        </a>
      </header>

      <!-- フッター (スライスの上・控えめな帯) -->
      <footer
        class="pointer-events-none absolute inset-x-0 bottom-0 z-10 flex items-end justify-between px-6 pb-5 md:px-10 md:pb-6"
      >
        <p
          class="font-display text-[9px] tracking-[0.4em] text-kg-text-muted/90 md:text-[10px]"
        >
          CREATING DIGITAL EXPERIENCES
        </p>
        <p
          class="font-display text-[9px] tracking-[0.3em] text-kg-text-muted/90 md:text-[10px]"
        >
          © 2026 KEIGOLY
        </p>
      </footer>
    </main>
  </body>
</html>
